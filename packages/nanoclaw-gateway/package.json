{
    "name": "@claw-pilot/nanoclaw-gateway",
    "version": "1.0.0",
    "description": "HTTP client for interfacing with NanoClaw devices",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
