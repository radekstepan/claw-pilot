# Copy this file to .env and fill in all required values.
# This is the single env file for the entire monorepo.

# ─── Backend ──────────────────────────────────────────────────────────────────

# TCP port the API server listens on.
PORT=54321

# Bind address (127.0.0.1 = loopback only; 0.0.0.0 = all interfaces/Docker/Tailscale).
HOST=127.0.0.1

# Publicly reachable base URL of this server, embedded into every agent prompt as the
# callback URL. Required when OpenClaw runs on a different machine (e.g. a VPS over
# Tailscale). If unset, agents receive http://localhost:{PORT} and cannot call back.
# Example (Tailscale): PUBLIC_URL=http://100.78.90.125:54321
# Example (Docker):    PUBLIC_URL=http://claw-pilot:54321
PUBLIC_URL=

# REQUIRED. Shared secret between the backend and frontend clients.
# Change this before deploying to any non-local environment.
API_KEY=

# The origin the frontend is served from (no trailing slash).
ALLOWED_ORIGIN=http://localhost:5173

# ─── OpenClaw Gateway ─────────────────────────────────────────────────────────

# WebSocket URL of the OpenClaw gateway.
OPENCLAW_GATEWAY_URL=ws://localhost:18789

# Bearer token appended as ?token=… when connecting to the gateway.
# Leave empty if the gateway has no auth configured.
OPENCLAW_GATEWAY_TOKEN=09GU7YMJhvrR

# Gateway ID used to build the main-agent session key.
OPENCLAW_GATEWAY_ID=gateway

# Timeout (ms) for fast RPC calls (e.g. sessions.list).
OPENCLAW_WS_TIMEOUT=15000

# Timeout (ms) for long-running AI generation calls (e.g. chat.send).
OPENCLAW_AI_TIMEOUT=120000

# Maximum number of AI gateway calls that may run concurrently (routeChatToAgent,
# spawnTaskSession). Additional jobs are queued and executed as slots free up.
# Lower values protect resource-constrained hosts running local LLMs; raise for
# capable servers. Must be between 1 and 50. Default: 3.
AI_QUEUE_CONCURRENCY=3

# Path to the Ed25519 device identity file (key pair + deviceToken).
# Override in Docker/VPS to point at a persistent volume.
OPENCLAW_DEVICE_IDENTITY_PATH=data/device-identity.json

# ─── Frontend (Vite - must be prefixed VITE_) ─────────────────────────────────

# URL of the backend API (no trailing slash).
VITE_API_URL=http://localhost:54321

# URL of the Socket.io server (usually the same as VITE_API_URL).
VITE_SOCKET_URL=http://localhost:54321

# Must match API_KEY above so the browser client can authenticate.
VITE_API_KEY=
