{
    "name": "backend",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "dev:mock": "node scripts/setup-mock-env.mjs && PATH=$(pwd)/scripts:$PATH OPENCLAW_HOME=$HOME/.openclaw-mock tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "eslint . --ext .ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@claw-pilot/shared-types": "*",
        "@fastify/cors": "^11.2.0",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/static": "^9.0.0",
        "better-sqlite3": "^12.6.2",
        "croner": "^10.0.1",
        "dotenv": "^16.4.5",
        "drizzle-orm": "^0.45.1",
        "fastify": "^5.0.0",
        "fastify-type-provider-zod": "^6.1.0",
        "socket.io": "^4.8.3",
        "ws": "^8.19.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^20.0.0",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "drizzle-kit": "^0.31.9",
        "eslint": "^8.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.0.0",
        "vitest": "^2.0.0"
    }
}
