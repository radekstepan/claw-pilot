#!/usr/bin/env node
/**
 * Mock OpenClaw CLI — used by `yarn dev:mock` so frontend developers can run
 * the full Claw-Pilot stack without needing Python or the real OpenClaw models.
 *
 * Intercepts every execFileAsync('openclaw', [...]) call via PATH ordering:
 * the scripts/ directory is prepended to PATH so this file shadows the real
 * openclaw binary (if any). Set OPENCLAW_HOME to a directory containing a
 * mock openclaw.json (created automatically by the dev:mock script).
 *
 * Supported sub-commands:
 *   sessions list --json         -> array of live agent sessions
 *   sessions spawn ...           -> success acknowledgement
 *   agent --agent <id> --json    -> mock AI text response (600 ms delay)
 *   models list --all --json     -> list of available LLM models
 */

const args = process.argv.slice(2);
const subcommand = args[0];

function respond(data) {
    process.stdout.write(JSON.stringify(data, null, 2));
    process.exit(0);
}

function fail(msg) {
    process.stderr.write('[mock-openclaw] ' + msg + '\n');
    process.exit(1);
}

if (subcommand === 'sessions') {
    const action = args[1];
    if (action === 'list') {
        respond([
            { agentId: 'architect', agent: 'architect', status: 'IDLE',    label: 'session-001' },
            { agentId: 'developer', agent: 'developer', status: 'WORKING', label: 'session-002' },
        ]);
    } else if (action === 'spawn') {
        const agentIdx = args.indexOf('--agent');
        const labelIdx = args.indexOf('--label');
        const agentId  = agentIdx !== -1 ? args[agentIdx + 1] : 'unknown';
        const label    = labelIdx !== -1 ? args[labelIdx + 1] : 'session';
        respond({ ok: true, agentId, label, message: '[mock] Session spawned.' });
    } else {
        fail('Unknown sessions action: ' + action);
    }
} else if (subcommand === 'agent') {
    const agentIdx   = args.indexOf('--agent');
    const messageIdx = args.indexOf('--message');
    const agentId    = agentIdx   !== -1 ? args[agentIdx   + 1] : 'main';
    const userMsg    = messageIdx !== -1 ? args[messageIdx + 1] : '';
    // Simulate realistic latency so the async 202 pattern is visible in dev.
    setTimeout(function() {
        respond({
            message: '[mock] Agent "' + agentId + '" received: "' + userMsg + '". Simulated response — no real LLM was invoked.',
        });
    }, 600);
} else if (subcommand === 'models') {
    respond([
        { id: 'claude-sonnet-4', alias: 'sonnet', provider: 'anthropic', available: true  },
        { id: 'claude-opus-4',   alias: 'opus',   provider: 'anthropic', available: true  },
        { id: 'gpt-4o',          alias: 'gpt4o',  provider: 'openai',    available: true  },
        { id: 'gemini-2.5-pro',  alias: 'gemini', provider: 'google',    available: false },
    ]);
} else {
    fail('Unknown subcommand: ' + subcommand);
}

