# Port the Fastify server listens on
PORT=54321

# Secret API key — must be set to a strong random value; server refuses to start if blank.
# Generate one with: openssl rand -hex 32
API_KEY=

# Allowed CORS origin — must be the exact URL of the frontend (no trailing slash).
# Cannot be "*". Defaults to http://localhost:5173 if unset.
ALLOWED_ORIGIN=http://localhost:5173

# Network interface the server binds to.
# Allowed: 127.0.0.1 | localhost | ::1 (local dev) or 0.0.0.0 (Docker containers).
HOST=127.0.0.1

# Root directory of the OpenClaw installation.
# Defaults to ~/.openclaw — override for Docker or custom install paths.
# OPENCLAW_HOME=/path/to/.openclaw

# Timeout (ms) for fast/informational CLI calls (sessions list, models list, --version, etc.)
CLI_TIMEOUT=15000

# Timeout (ms) for heavy AI CLI calls (chat, generate, spawn session).
AI_TIMEOUT=120000

